# ── Supabase ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── Administración ────────────────────────────────────────────────────────────
# Emails separados por coma autorizados a acceder al panel admin
ADMIN_EMAILS=admin@tudominio.com,otro@tudominio.com

# ── Tienda ────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_STORE_NAME=AG Laptops
NEXT_PUBLIC_SITE_URL=https://tudominio.com
NEXT_PUBLIC_CONTACT_EMAIL=ventas@tudominio.com
NEXT_PUBLIC_WHATSAPP_NUMBER=51999999999

# Tipo de cambio USD → PEN (actualiza sin redeploy)
NEXT_PUBLIC_TC_USD_PEN=3.75

# ── Meta / Facebook ───────────────────────────────────────────────────────────
NEXT_PUBLIC_FB_PIXEL_ID=1234567890
NEXT_PUBLIC_FB_DOMAIN_VERIFICATION=abc123xyz

# ── Rate limiter (Upstash Redis) ──────────────────────────────────────────────
# Crea una base de datos gratuita en https://console.upstash.com
# Sin estas variables se usa un fallback en memoria (solo válido en desarrollo)
UPSTASH_REDIS_REST_URL=https://tu-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=AX...
